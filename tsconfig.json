{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "micromark-extension-chart-markup": ["./packages/micromark-extension-chart-markup/src/index.ts"],
      "mdast-util-chart-markup": ["./packages/mdast-util-chart-markup/src/index.ts"],
      "@philippe-laval/plugin-chart-markup": ["./packages/plugin-chart-markup/src/index.ts"],
      "@philippe-laval/plugin-chart-markup-react": ["./packages/plugin-chart-markup-react/src/index.tsx"]
    }
  },
  "include": ["packages/*/src/**/*", "playground/src/**/*", "e2e/**/*"]
}
