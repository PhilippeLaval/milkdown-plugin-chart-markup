# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo
.turbo/

# tsc -b emit pollution (root tsconfig has no outDir, so `tsc -b` writes next to sources)
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
playground/src/**/*.js
playground/src/**/*.js.map
playground/src/**/*.d.ts
playground/src/**/*.d.ts.map
e2e/**/*.js
e2e/**/*.js.map
e2e/**/*.d.ts
e2e/**/*.d.ts.map

# Test output
coverage/
.nyc_output/
playwright-report/
test-results/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*~
