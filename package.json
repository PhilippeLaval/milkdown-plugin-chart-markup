{
  "name": "milkdown-plugin-chart-markup-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for milkdown-plugin-chart-markup",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "playground": "pnpm --filter chart-markup-playground dev",
    "showboat:verify": "npx -y showboat verify showboat/walkthrough.md",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@rollup/rollup-darwin-x64": "^4.60.1",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.6.0",
    "happy-dom": "^14.7.1",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "packageManager": "pnpm@9.0.0"
}
