{
  "name": "@philippe-laval/plugin-chart-markup",
  "version": "0.2.0",
  "description": "Milkdown plugin adding first-class chart blocks backed by a canonical fenced-code markdown representation",
  "license": "MIT",
  "author": "Philippe Laval",
  "keywords": [
    "milkdown",
    "milkdown-plugin",
    "prosemirror",
    "markdown",
    "chart",
    "chart.js",
    "fenced-code"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PhilippeLaval/milkdown-plugin-chart-markup.git",
    "directory": "packages/plugin-chart-markup"
  },
  "bugs": {
    "url": "https://github.com/PhilippeLaval/milkdown-plugin-chart-markup/issues"
  },
  "homepage": "https://github.com/PhilippeLaval/milkdown-plugin-chart-markup/tree/main/packages/plugin-chart-markup#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "mdast-util-chart-markup": "workspace:*",
    "micromark-extension-chart-markup": "workspace:*"
  },
  "peerDependencies": {
    "@milkdown/core": ">=7.0.0",
    "@milkdown/preset-commonmark": ">=7.0.0",
    "chart.js": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@milkdown/core": {
      "optional": true
    },
    "@milkdown/preset-commonmark": {
      "optional": true
    },
    "chart.js": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
