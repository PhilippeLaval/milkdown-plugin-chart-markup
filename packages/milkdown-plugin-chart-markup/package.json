    "@milkdown/utils": ">=7.0.0",
    "chart.js": ">=4.0.0"
  },
  "devDependencies": {
    "@milkdown/core": "^7.20.0",
    "@milkdown/ctx": "^7.20.0",
    "@milkdown/preset-commonmark": "^7.20.0",
    "@milkdown/prose": "^7.20.0",
