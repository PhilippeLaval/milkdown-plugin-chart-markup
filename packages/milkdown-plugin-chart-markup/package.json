    "fenced-code"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PhilippeLaval/milkdown-plugin-chart-markup.git",
    "directory": "packages/milkdown-plugin-chart-markup"
  },
  "bugs": {
    "url": "https://github.com/PhilippeLaval/milkdown-plugin-chart-markup/issues"
  },
  "homepage": "https://github.com/PhilippeLaval/milkdown-plugin-chart-markup/tree/main/packages/milkdown-plugin-chart-markup#readme",
  "type": "module",
  "main": "./dist/index.js",
