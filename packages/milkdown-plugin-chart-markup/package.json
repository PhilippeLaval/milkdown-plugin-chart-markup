{
  "name": "@philippe-laval/milkdown-plugin-chart-markup",
  "version": "0.1.0",
  "description": "Turn-key Milkdown plugin that adds first-class chart blocks backed by @philippe-laval/plugin-chart-markup primitives",
  "license": "MIT",
  "author": "Philippe Laval",
  "keywords": [
    "milkdown",
    "milkdown-plugin",
    "prosemirror",
    "markdown",
    "chart",
